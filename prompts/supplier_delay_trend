### Web Implementation Pseudocode

```javascript
// For each supplier:
function calculateSupplierMetrics(supplierName, lwData, cwData) {
    // Count LW delays
    const lwDelays = lwData.filter(row => 
        row.supplier === supplierName && 
        row.onTimeDelay === "Delay"
    ).length;
    
    // Count CW delays  
    const cwDelays = cwData.filter(row => 
        row.supplier === supplierName && 
        row.onTimeDelay === "Delay"
    ).length;
    
    // Calculate delta
    const deltaChange = cwDelays - lwDelays;
    
    // Determine trend
    const trend = cwDelays < lwDelays ? "✅ Improved" : "🔴 Worsened";
    
    return { supplierName, lwDelays, cwDelays, deltaChange, trend };
}
```

